# App
APP_NAME=AI Email Assistant
DEBUG=false
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
ENCRYPTION_KEY=

DATABASE_URL=sqlite:///./data/email_assistant.db

# Polling
IMAP_POLL_INTERVAL=60
DASHBOARD_REFRESH_INTERVAL=60

# Ollama SLM (local AI — requires Ollama installed)
OLLAMA_ENABLED=false
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=30

# Groq Cloud AI (set OLLAMA_ENABLED=false and add your key)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama3-8b

# SMTP (for sending emails — only needed if user hasn't set up IMAP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_DEFAULT_SENDER=

# Gmail OAuth (optional — App Password is preferred)
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REDIRECT_URI=http://localhost:8000/auth/gmail/callback

# Cron secret for external sync triggers (cron-job.org, UptimeRobot)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(16))"
CRON_SECRET=
