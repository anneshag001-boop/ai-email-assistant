# App
APP_NAME=AI Email Assistant
DEBUG=false
SECRET_KEY=your-secret-key-here
ENCRYPTION_KEY=your-encryption-key-here

# Database (SQLite default, set USE_POSTGRES=true + DATABASE_URL for PostgreSQL)
DATABASE_URL=sqlite:///./data/email_assistant.db
USE_POSTGRES=false
POSTGRES_USER=email_assistant
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=email_assistant

# Gmail OAuth2
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/auth/gmail/callback

# Outlook / Microsoft Graph OAuth2
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=http://localhost:8000/auth/outlook/callback
OUTLOOK_TENANT=common

# SpamAssassin
SPAMASSASSIN_ENABLED=false
SPAMASSASSIN_HOST=127.0.0.1
SPAMASSASSIN_PORT=783

# Ollama SLM (Small Language Model)
OLLAMA_ENABLED=true
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=30

# AI Thresholds
SPAM_THRESHOLD=0.7
CONFIDENCE_THRESHOLD=0.6

# Cleanup
SPAM_RETENTION_DAYS=30

# SMTP (for sending emails via Compose / Reply)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_DEFAULT_SENDER=

# Dashboard
DASHBOARD_REFRESH_INTERVAL=60
