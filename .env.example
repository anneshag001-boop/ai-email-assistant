# App
APP_NAME=AI Email Assistant
DEBUG=false
SECRET_KEY=your-secret-key-here
ENCRYPTION_KEY=your-encryption-key-here

DATABASE_URL=sqlite:///./data/email_assistant.db

# Ollama SLM (local AI — requires Ollama installed)
OLLAMA_ENABLED=true
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=30

# Groq Cloud AI (set OLLAMA_ENABLED=false and add your key)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama3-8b

# SMTP (for sending emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_DEFAULT_SENDER=
